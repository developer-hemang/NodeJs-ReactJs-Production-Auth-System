# ===============================

# Node + React Full Stack Ignore

# ===============================

# Logs

logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Runtime files

pids
*.pid
*.seed
*.pid.lock

# Diagnostic reports

report.*.json

# Dependency directories

node_modules/
frontend/node_modules/
backend/node_modules/

# Build output

dist/
build/
frontend/dist/
backend/dist/

# Coverage reports

coverage/
.nyc_output
*.lcov

# Cache directories

.cache
.parcel-cache
.eslintcache
.stylelintcache
.vite
.temp

# Environment variables

.env
.env.*
!.env.example

# TypeScript

*.tsbuildinfo

# Optional npm cache

.npm

# Optional REPL history

.node_repl_history

# Editor directories

.vscode/
.idea/
.vscode-test

# OS files

.DS_Store
Thumbs.db

# React / Vite specific

vite.config.js.timestamp-*
vite.config.ts.timestamp-*

# Framework build outputs

.next
.nuxt
.svelte-kit
.vuepress/dist
.docusaurus

# Serverless

.serverless/

# Firebase

.firebase/

# DynamoDB Local

.dynamodb/

# Yarn v3

.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/sdks
!.yarn/versions
